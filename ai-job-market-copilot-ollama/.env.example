# Optional: set to true to enable Hugging Face fallback when Ollama fails.
ENABLE_HF_FALLBACK=false

# Optional: Hugging Face token (already available in Ahmad's machine env, but set here for portability)
HF_TOKEN=

# Ollama settings
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=granite4.1:3b
OLLAMA_QUALITY_MODEL=granite4.1:8b
OLLAMA_TEMPERATURE=0.0

# Pipeline sizing
MAX_JOBS_PER_SOURCE=500
MAX_JOBS_FOR_ENRICHMENT=12
AI_KEYWORD_THRESHOLD=2
